# Make a copy of this to set environment variables for local development
# cp .env.example .env

# TODO: Fill in auth related env vars
DATABRICKS_CONFIG_PROFILE=DEFAULT
# DATABRICKS_HOST=https://<your-workspace-here>.databricks.com
# DATABRICKS_TOKEN=dapi....

# Agent backend mode:
# - databricks: Use Databricks model + Databricks MCP tools (default unless OPENAI_API_KEY is set)
# - openai: Extension-like local mode using standard OpenAI-compatible API key
AGENT_BACKEND=openai
AGENT_MODEL=gpt-4.1-mini
AGENT_FALLBACK_MODEL=gpt-4.1
AGENT_MAX_RETRIES=3
AGENT_RETRY_BASE_SECONDS=1.5
OPENAI_API_KEY=<your-openai-api-key>
# Optional custom provider endpoint (OpenAI-compatible):
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional memory backend selection:
MEMORY_BACKEND=inmemory
# MEMORY_BACKEND=cosmos
# COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
# COSMOS_KEY=<key>
# COSMOS_DATABASE=agent_memory
# COSMOS_CONTAINER=messages

# TODO: Update with the MLflow experiment you want to log traces and models to
MLFLOW_EXPERIMENT_ID=

CHAT_APP_PORT=3000
CHAT_PROXY_TIMEOUT_SECONDS=300
# IMPORTANT: For local development, use databricks (for default profile) or databricks://<profile-name> to specify which Databricks CLI profile to use
# This is automatically configured by the quickstart script
MLFLOW_TRACKING_URI="databricks"
MLFLOW_REGISTRY_URI="databricks-uc"
